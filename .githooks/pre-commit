#!/usr/bin/env sh
#
# Pre-commit hook — runs linters on staged files only.
#
# Activate once per clone:
#   git config core.hooksPath .githooks
#
# Linters run from the theme directory where their configs live.
# Requires: composer install (phpcs) and pnpm install (eslint, stylelint).

THEME_DIR="wp-content/themes/core-wp"
FAILED=0

# Git hooks run with a minimal PATH. Add common node binary locations so
# tools installed via nvm, Homebrew, or system packages are all findable.
if ! command -v node > /dev/null 2>&1; then
    NVM_NODE=$(find "$HOME/.nvm/versions/node" -type f -name "node" -maxdepth 3 2>/dev/null | head -1)
    [ -n "$NVM_NODE" ] && export PATH="$(dirname "$NVM_NODE"):$PATH"
fi

# Staged files by type, paths relative to theme root
PHP_FILES=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep "^${THEME_DIR}/.*\.php$" \
    | sed "s|^${THEME_DIR}/||")

JS_FILES=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep "^${THEME_DIR}/theme_components/js/.*\.js$" \
    | sed "s|^${THEME_DIR}/||")

SCSS_FILES=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep "^${THEME_DIR}/theme_components/sass/.*\.scss$" \
    | sed "s|^${THEME_DIR}/||")

cd "$THEME_DIR" || exit 1

if [ -n "$PHP_FILES" ]; then
    printf '\033[0;34m[phpcs]\033[0m Checking staged PHP files...\n'
    printf '%s\n' "$PHP_FILES" | xargs php ../../vendor/bin/phpcs --standard=phpcs.xml --basepath=./ || FAILED=1
fi

if [ -n "$JS_FILES" ]; then
    printf '\033[0;34m[eslint]\033[0m Checking staged JS files...\n'
    printf '%s\n' "$JS_FILES" | xargs ./node_modules/.bin/eslint || FAILED=1
fi

if [ -n "$SCSS_FILES" ]; then
    printf '\033[0;34m[stylelint]\033[0m Checking staged SCSS files...\n'
    printf '%s\n' "$SCSS_FILES" | xargs ./node_modules/.bin/stylelint || FAILED=1
fi

if [ "$FAILED" -ne 0 ]; then
    printf '\033[0;31mPre-commit checks failed. Fix the errors above before committing.\033[0m\n'
    exit 1
fi

exit 0
