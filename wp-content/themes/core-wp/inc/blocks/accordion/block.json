{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "core-wp/accordion",
	"version": "1.0.0",
	"title": "Accordion",
	"category": "core-wp",
	"description": "Collapsible accordion with optional float or 50/50 split layout.",
	"textdomain": "core_wp",
	"editorScript": "core-wp-accordion-editor",
	"attributes": {
		"layout": {
			"type": "string",
			"default": "full"
		},
		"floatDirection": {
			"type": "string",
			"default": "left"
		},
		"splitLayout": {
			"type": "boolean",
			"default": false
		},
		"singleOpen": {
			"type": "boolean",
			"default": false
		}
	},
	"supports": {
		"html": false,
		"reusable": false
	}
}
