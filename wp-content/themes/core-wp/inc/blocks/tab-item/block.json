{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "core-wp/tab-item",
	"version": "1.0.0",
	"title": "Tab Item",
	"category": "core-wp",
	"description": "A single tab with a title and rich content area. Must be used inside the Tabs block.",
	"textdomain": "core_wp",
	"parent": ["core-wp/tabs"],
	"editorScript": "core-wp-tab-item-editor",
	"attributes": {
		"title": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"reusable": false
	}
}
