{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"name": "Primary",
					"slug": "primary",
					"color": "#000000"
				},
				{
					"name": "Secondary",
					"slug": "secondary",
					"color": "#000000"
				},
				{
					"name": "Tertiary",
					"slug": "tertiary",
					"color": "#cccccc"
				},
				{
					"name": "White",
					"slug": "white",
					"color": "#fefefe"
				},
				{
					"name": "Black",
					"slug": "black",
					"color": "#0a0a0a"
				},
				{
					"name": "Light Gray",
					"slug": "light-gray",
					"color": "#e6e6e6"
				},
				{
					"name": "Medium Gray",
					"slug": "medium-gray",
					"color": "#cacaca"
				},
				{
					"name": "Dark Gray",
					"slug": "dark-gray",
					"color": "#8a8a8a"
				},
				{
					"name": "Dark Navy",
					"slug": "dark-navy",
					"color": "#0d1b2e"
				},
				{
					"name": "Green Blue",
					"slug": "accent-green-blue",
					"color": "#3d79df"
				}
			]
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1600px"
		},
		"spacing": {
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"spacingSizes": [
				{ "slug": "1", "size": "0.25rem", "name": "XSmall" },
				{ "slug": "2", "size": "0.5rem",  "name": "Small" },
				{ "slug": "3", "size": "1rem",    "name": "Medium" },
				{ "slug": "4", "size": "1.5rem",  "name": "Large" },
				{ "slug": "5", "size": "2rem",    "name": "XLarge" },
				{ "slug": "6", "size": "3rem",    "name": "XXLarge" },
				{ "slug": "7", "size": "4rem",    "name": "Huge" }
			]
		},
		"typography": {
			"customFontSize": true,
			"fontFamilies": [
				{
					"name": "System Sans-Serif",
					"slug": "sans-serif",
					"fontFamily": "\"Helvetica Neue\", helvetica, roboto, arial, sans-serif"
				},
				{
					"name": "Monospace",
					"slug": "monospace",
					"fontFamily": "consolas, \"Liberation Mono\", courier, monospace"
				}
			],
			"fontSizes": [
				{ "slug": "small",   "size": "0.8rem",   "name": "Small" },
				{ "slug": "medium",  "size": "1rem",     "name": "Medium" },
				{ "slug": "large",   "size": "1.25rem",  "name": "Large" },
				{ "slug": "x-large", "size": "1.5rem",   "name": "X Large" },
				{ "slug": "xx-large","size": "2rem",     "name": "XX Large" },
				{ "slug": "huge",    "size": "3rem",     "name": "Huge" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--black)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans-serif)",
			"fontSize": "1rem",
			"lineHeight": "1.5"
		},
		"elements": {
			"h1": { "typography": { "fontSize": "3rem",       "lineHeight": "1.4" } },
			"h2": { "typography": { "fontSize": "2.5rem",     "lineHeight": "1.4" } },
			"h3": { "typography": { "fontSize": "1.9375rem",  "lineHeight": "1.4" } },
			"h4": { "typography": { "fontSize": "1.5625rem",  "lineHeight": "1.4" } },
			"h5": { "typography": { "fontSize": "1.25rem",    "lineHeight": "1.4" } },
			"h6": { "typography": { "fontSize": "1rem",       "lineHeight": "1.4" } }
		}
	}
}
