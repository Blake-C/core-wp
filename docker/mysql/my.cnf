[mysqld]
# InnoDB buffer pool: aim for ~50-70% of available server RAM.
# 1G is a reasonable starting point; tune based on your host's memory.
innodb_buffer_pool_size        = 1G

# Multiple buffer pool instances reduce mutex contention under concurrent load.
# Recommended: 1 instance per GB of buffer pool size.
innodb_buffer_pool_instances   = 2

# Log buffer size — larger than dev since prod sees higher write volume.
innodb_log_buffer_size         = 32M

# Cache threads to avoid creation overhead on repeated short-lived connections.
thread_cache_size              = 16

# Flush once per second — trades up to 1 second of data on hard crash for
# significantly better write throughput. Acceptable for most WordPress sites.
innodb_flush_log_at_trx_commit = 2

# O_DIRECT bypasses the OS page cache for InnoDB data files, preventing
# double-buffering when the buffer pool is large.
innodb_flush_method            = O_DIRECT

# Log slow queries — essential for catching regressions in prod.
slow_query_log                 = 1
slow_query_log_file            = /var/log/mysql/slow.log
long_query_time                = 1

# UTF-8 everywhere — matches WordPress defaults.
character_set_server           = utf8mb4
collation_server               = utf8mb4_unicode_ci
